# ==========================================
# CẤU HÌNH MÔI TRƯỜNG STUDYHUB BACKEND
# ==========================================
# Copy file này thành .env hoặc .env.production và điền thông tin thực tế.

# --- Database PostgreSQL ---
DB_USER = "postgres"
DB_NAME = "studyhubdb"
DB_PASSWORD = "your_secure_password"
DB_HOST = "localhost"
DB_PORT = 5432

# --- Server & CORS ---
SERVER_PORT = 8081
# Phân tách nhiều origin bằng dấu phẩy nếu cần: http://localhost:5173,https://studyhub.vn,https://www.studyhub.vn
FRONTEND_BASE_URL = "http://localhost:5173"

# --- JWT Secrets & Security ---
JWT_ACCESS_SECRET = "Replace_With_Your_Strong_Secret_Key_For_Access_Token"
JWT_REFRESH_SECRET = "Replace_With_Your_Strong_Secret_Key_For_Refresh_Token"

BCRYPT_SALT_ROUNDS = 10

# --- Timeouts & Expire ---
JWT_ACCESS_EXPIRES_IN = "15m"
JWT_REFRESH_EXPIRES_IN = "7d"
REFRESH_TOKEN_DAYS = 7

# ==========================================
# CẢNH BÁO QUAN TRỌNG KHI DEPLOY PRODUCTION
# ==========================================
# 1. DB_SYNCHRONIZE: Bắt buộc đặt false trên Production! Nếu đặt true, TypeORM có thể tự động DROP/SỬA bảng làm mất sạch dữ liệu thật.
# 2. DB_LOGGING: Bắt buộc đặt false trên Production để tránh in SQL kèm dữ liệu nhạy cảm ra log file/console và tối ưu hiệu năng.
DB_SYNCHRONIZE = false
DB_LOGGING = false
