### =========================================================================
### STUDYHUB AUTHENTICATION TESTING SUITE (.http file format)
### Sử dụng với VS Code Extension: REST Client hoặc Thunder Client / Postman.
### =========================================================================

@baseUrl = http://localhost:8081/api/v1/auth
@contentType = application/json

### -------------------------------------------------------------------------
### BƯỚC 0: CHUẨN BỊ DỮ LIỆU MẪU (SQL SEED)
### Chạy các câu lệnh SQL dưới đây trong database của bạn (studyhubdb)
### để tránh lỗi khi đăng ký STUDENT hoặc LECTURER theo Business Code:
###
### INSERT INTO cohorts (code, name, start_year, end_year) VALUES ('K1', 'Khóa 1', 2023, 2027) ON CONFLICT DO NOTHING;
### INSERT INTO faculties (code, name, description) VALUES ('CNTT', 'Khoa Công nghệ thông tin', 'Khoa CNTT') ON CONFLICT DO NOTHING;
### INSERT INTO majors (code, faculty_id, name, description) VALUES ('BIT', 1, 'Kỹ thuật phần mềm', 'Ngành lập trình') ON CONFLICT DO NOTHING;
### -------------------------------------------------------------------------


### =========================================================================
### 1. ĐĂNG KÝ TÀI KHOẢN (POST /register)
### =========================================================================

### 1.1 Đăng ký sinh viên CNTT (STUDENT - K1, CNTT, BIT)
POST {{baseUrl}}/register
Content-Type: {{contentType}}

{
  "code": "BIT250051",
  "full_name": "Nguyễn Văn Sinh Viên CNTT",
  "username": "sinhvienbit",
  "email": "sinhvienbit@studyhub.edu.vn",
  "phone": "0912345671",
  "dob": "2003-05-20",
  "password": "Sinhvien@123",
  "role": "STUDENT",
  "cohort_code": "K1",
  "faculty_code": "CNTT",
  "major_code": "BIT"
}

